APP_NAME="Secure-Talent ATS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

# Security
BLIND_INDEX_KEY=base64:$(openssl rand -base64 32)

# Docker/Infrastructure
USER_NAME=sammy
USER_ID=1000
APP_PORT=8000

LOG_CHANNEL=stack
LOG_STACK=single

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=secure_talent
DB_USERNAME=secure_user
DB_PASSWORD=secret

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6373

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="admin@secure-talent.com"
MAIL_FROM_NAME="${APP_NAME}"

QUEUE_CONNECTION=redis

SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Google Drive Storage
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
BLIND_INDEX_KEY=
